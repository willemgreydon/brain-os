{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@brain/graph-core": ["packages/graph-core/src"],
      "@brain/knowledge-engine": ["packages/knowledge-engine/src"],
      "@brain/semantic-engine": ["packages/semantic-engine/src"],
      "@brain/ai-gap-engine": ["packages/ai-gap-engine/src"],
      "@brain/ui": ["packages/ui/src"]
    }
  }
}
